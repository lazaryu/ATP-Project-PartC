<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>

        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%-5level] %c{1} - %msg%n"/>
        </Console>

        <RollingFile name="FileLogger"
                     fileName="logs/pacmaze.log"
                     filePattern="logs/pacmaze-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss}] [%-5level] [%t] %c{1} - %msg%n"/>

            <Policies>
                <SizeBasedTriggeringPolicy size="5MB"/>
            </Policies>

            <DefaultRolloverStrategy max="5"/>
        </RollingFile>

    </Appenders>

    <Loggers>

        <Root level="debug">
            <AppenderRef ref="Console" level="info"/>
            <AppenderRef ref="FileLogger" level="debug"/>
        </Root>

    </Loggers>

</Configuration>
