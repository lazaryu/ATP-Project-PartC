<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.atpprojectpartc.View.MyViewController">

    <top>
        <Label text="Maze Game"
               style="-fx-font-size: 24px; -fx-font-weight: bold;"
               BorderPane.alignment="CENTER"/>
    </top>

    <left>
        <VBox spacing="10.0" prefWidth="200.0">
            <padding>
                <Insets top="15.0" right="10.0" bottom="15.0" left="10.0"/>
            </padding>

            <Label text="Rows:"/>
            <TextField fx:id="textField_mazeRows" text="50"/>

            <Label text="Columns:"/>
            <TextField fx:id="textField_mazeColumns" text="50"/>

            <Button text="Generate Maze"
                    onAction="#generateMaze"
                    prefWidth="180.0"/>

            <Label fx:id="statusLabel"
                   text="Generate a maze to start."
                   wrapText="true"/>
        </VBox>
    </left>

    <center>
        <Pane fx:id="mazeContainer"
              prefWidth="650.0"
              prefHeight="550.0"
              focusTraversable="true"
              style="-fx-border-color: black; -fx-background-color: #ECEFF1;"/>
    </center>

</BorderPane>